<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.letsparaconnect.ops-monitor</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>node</string>
      <string>__PROJECT_ROOT__/backend/scripts/ops-monitor.js</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
      <key>MONGO_URI</key>
      <string>__MONGO_URI__</string>
      <key>OPS_HEALTHCHECK_URL</key>
      <string>__OPS_HEALTHCHECK_URL__</string>
      <key>OWNER_ALERT_EMAILS</key>
      <string>__OWNER_ALERT_EMAILS__</string>
      <key>BACKUP_STATUS_FILE</key>
      <string>__BACKUP_STATUS_FILE__</string>
      <key>OPS_MONITOR_STATE_FILE</key>
      <string>__OPS_MONITOR_STATE_FILE__</string>
    </dict>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__LOG_PATH__</string>
    <key>StandardErrorPath</key>
    <string>__LOG_PATH__</string>
  </dict>
</plist>
